# ============================================================
# Tele Quant local secrets/config
# 1) TELEGRAM_API_ID / TELEGRAM_API_HASH만 먼저 넣어도 됩니다.
# 2) 첫 로그인은 `uv run tele-quant auth`에서 문자/텔레그램 인증코드를 입력합니다.
# 3) 기본 전송 위치는 내 Saved Messages입니다: TELEGRAM_TARGET_CHAT=me
# ============================================================

# --- Telegram user API: https://my.telegram.org/apps 에서 발급 ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION_PATH=./data/tele_quant.session

# --- 읽을 채널 선택 ---
# true: 내가 팔로우한 모든 채널(시스템/개인/봇 제외)을 읽음. 주식채널만 팔로우하면 true 권장.
TELEGRAM_INCLUDE_ALL_CHANNELS=true
# 특정 채널만 지정할 때 쉼표로 구분 (INCLUDE_ALL=false일 때만 사용)
TELEGRAM_SOURCE_CHATS=KiwoomResearch,HanaResearch,meritz_research,yuantaresearch,daolresearch,hmsecresearch,sksresearch,sk_smallcap,shsmallcap,eqmirae,companyreport

# --- 수집/요약 주기 ---
FETCH_LOOKBACK_HOURS=4
DIGEST_INTERVAL_HOURS=4
MAX_MESSAGES_PER_CHAT=120
MAX_ITEMS_FOR_DIGEST=160
MIN_TEXT_CHARS=20

# --- 전송 ---
# user: Telethon 사용자 계정으로 전송. 기본은 Saved Messages(me).
# bot: BotFather 토큰으로 전송. 이 경우 TELEGRAM_BOT_TOKEN / TELEGRAM_BOT_TARGET_CHAT_ID 필요.
TELEGRAM_SEND_MODE=user
TELEGRAM_TARGET_CHAT=me
# bot 모드일 때만 채움. 토큰 노출 주의 - 노출 시 BotFather에서 즉시 재발급!
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TARGET_CHAT_ID=

# --- Ollama local AI ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=gwani-dev:latest
OLLAMA_EMBED_MODEL=gwani-dev:latest
OLLAMA_TEMPERATURE=0.15
OLLAMA_NUM_CTX=32768
# 전체 채널 딥요약 시 오래 걸릴 수 있으므로 3600(1시간)으로 설정
OLLAMA_TIMEOUT_SECONDS=3600

# --- 중복 제거 ---
FUZZY_DEDUPE_THRESHOLD=92
# 임베딩 디듀프는 속도가 느리므로 기본 false 권장
EMBEDDING_DEDUPE=false
EMBEDDING_DEDUPE_THRESHOLD=0.88
EMBEDDING_MAX_ITEMS=220

# --- Yahoo Finance market snapshot ---
YFINANCE_ENABLED=true
YFINANCE_SYMBOLS=^GSPC,^IXIC,^DJI,^VIX,^TNX,DX-Y.NYB,KRW=X,^KS11,^KQ11,005930.KS,000660.KS,NVDA,MSFT,AAPL,TSLA,BTC-USD

# --- Naver Finance official/public research reports ---
NAVER_REPORTS_ENABLED=true
NAVER_REPORT_CATEGORIES=company,industry,economy,market
NAVER_REPORTS_PER_CATEGORY=10
NAVER_DOWNLOAD_PDFS=false
NAVER_MAX_PDFS_PER_RUN=3
NAVER_PDF_MAX_PAGES=2
NAVER_PDF_MAX_CHARS=2500

# --- Storage ---
SQLITE_PATH=./data/tele_quant.sqlite

# --- 자기참조/봇 결과물 재수집 방지 ---
# 출력 채널명을 쉼표로 구분해서 넣으면 수집에서 제외됨 (예: 과니의 주식요약)
TELEGRAM_EXCLUDE_CHATS=
DROP_SELF_GENERATED_MESSAGES=true
SELF_GENERATED_MARKERS=Tele Quant,관심 진입,손절/무효화,목표/매도 관찰,공개 정보 기반 개인 리서치

# --- Source quality 필터 ---
# true이면 SOURCE_QUALITY_MIN_SCORE 미만 메시지 버림
SOURCE_QUALITY_ENABLED=true
SOURCE_QUALITY_MIN_SCORE=2
SOURCE_QUALITY_STRICT_MODE=false

# --- Evidence 클러스터 (Ollama 입력 압축) ---
EVIDENCE_MAX_CLUSTERS=80
EVIDENCE_MAX_MACRO_CLUSTERS=25
EVIDENCE_MAX_POSITIVE_STOCK_CLUSTERS=35
EVIDENCE_MAX_NEGATIVE_STOCK_CLUSTERS=35
EVIDENCE_MIN_CLUSTER_SCORE=2.0

# --- 외부 API 키 (선택사항, 모두 없어도 yfinance로 동작) ---
# 값 노출 금지 — 절대 로그/출력하지 말 것
FRED_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
NEWSAPI_KEY=
TAVILY_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- Digest 품질 (map-reduce) ---
# DIGEST_CHUNK_SIZE: 한 번에 Ollama에 넣을 뉴스 묶음 크기
DIGEST_CHUNK_SIZE=25
# DIGEST_CHUNK_SUMMARIES: true이면 chunk별 요약 후 최종 합성 (권장)
DIGEST_CHUNK_SUMMARIES=true
# DIGEST_QUALITY_MODE: deep(권장) 또는 fast
DIGEST_QUALITY_MODE=deep

# --- 종목 분석 ---
# ANALYSIS_ENABLED: true이면 once/loop 실행 시 종목 시나리오 두 번째 메시지도 전송
ANALYSIS_ENABLED=true
ANALYSIS_TOP_CANDIDATES=8
ANALYSIS_MAX_SYMBOLS=15
# 이 점수(0-100) 이상인 종목만 전송
ANALYSIS_MIN_SCORE_TO_SEND=55
ANALYSIS_MARKET_DATA_PERIOD=6mo
ANALYSIS_MARKET_DATA_INTERVAL=1d

# --- Fast Digest Mode ---
# fast: Python이 대부분 정리하고 Ollama는 최종 문장 polish만 함 (권장)
# deep: evidence-pack LLM 합성 방식 유지 (느리지만 더 풍부)
# no_llm: Ollama 없이 Python 리포트만 생성 (가장 빠름)
DIGEST_MODE=fast
OLLAMA_POLISH_ONLY=true
OLLAMA_FINAL_TIMEOUT_SECONDS=180
OLLAMA_MAX_EVIDENCE_FOR_PROMPT=28
OLLAMA_MAX_MACRO_EVIDENCE=8
OLLAMA_MAX_POSITIVE_EVIDENCE=10
OLLAMA_MAX_NEGATIVE_EVIDENCE=10
DETERMINISTIC_FALLBACK=true

# --- 실행 시간 제한 ---
RUN_MAX_SECONDS=900
OLLAMA_CALL_MAX_SECONDS=180
ANALYSIS_MAX_TICKERS=8
YFINANCE_BATCH_SIZE=20

# --- 외부 env 경로 (선택) ---
# Windows Downloads 폴더에 .env.local이 있으면 자동 로드 (키 값 절대 출력 안 함)
EXTERNAL_ENV_PATH=/mnt/c/Users/runkw/Downloads/.env.local
PROVIDER_VERIFY_ENABLED=true

# --- 평일 4시간 fast / 주말 weekly 운영 권장값 ---
# 평일 fast: DIGEST_MODE=fast + OLLAMA_POLISH_ONLY=true (빠르게)
# 주말 weekly: Ollama deep_polish (시간 여유 있음, 안정적이어야 함)
WEEKLY_ENABLED=true
WEEKLY_LOOKBACK_DAYS=7
# deep_polish: Ollama로 문장 다듬기 / no_llm: 순수 Python 집계만
WEEKLY_MODE=deep_polish
WEEKLY_OLLAMA_TIMEOUT_SECONDS=600
WEEKLY_MAX_REPORTS=60
WEEKLY_SEND_DAY=SAT
WEEKLY_SEND_HOUR=9

# --- Relation feed 신선도 ---
# 40시간 초과 시 relation feed 상세 섹션을 리포트에서 완전히 생략
RELATION_FEED_MAX_AGE_HOURS=40
